{
  "provider": "google-ai-studio",
  "model": "gemini-2.0-pro-exp-02-05",
  "env": {
    "GOOGLE_API_KEY": "YOUR_API_KEY_HERE"
  },
  "subagents": {
    "defaultModel": "gemini-2.0-flash",
    "enable": true
  },
  "experimental": {
    "enableAgents": true,
    "alwaysThinkingEnabled": true
  },
  "permissions": {
    "allow": [
      "read_file",
      "write_file",
      "list_directory",
      "glob",
      "grep_search",
      "run_shell_command",
      "google_web_search",
      "web_fetch"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(npm publish:*)"
    ]
  }
}
